{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "package.json"
  },
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.module.ts",
    "!src/**/*.spec.ts",
    "!src/main.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  },
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "coverageAnalysis": "perTest"
}
